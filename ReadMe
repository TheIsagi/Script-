--// Variables & Configuration State
local AutoBuy = false
local AutoUpgrade = false
local AutoPower = false
local AutoFruit = false
local AutoPhone = false
local AutoRebirth = false
local AutoEvolve = false
local AutoAscend = false
local AutoCashDrop = false
local AutoVine = false
local AutoReconnect = false
local AutoSaveConfig = false
local TARGET_MULTIPLIER = 100 

local stats = { 
    buys = 0, upgrades = 0, powers = 0, fruit = 0, rebirths = 0, 
    evolves = 0, ascends = 0, cashdrops = 0, phones = 0, vines = 0
}

local Elements = { Toggles = {}, Dropdowns = {} }
local ConfigFile = "VibeCodey_Lemon_Config.json"

--// Config System Functions
local function SaveConfig(silent)
    if not writefile then return end
    local data = {
        AutoBuy = AutoBuy,
        AutoUpgrade = AutoUpgrade,
        AutoPower = AutoPower,
        AutoFruit = AutoFruit,
        AutoPhone = AutoPhone,
        AutoRebirth = AutoRebirth,
        TARGET_MULTIPLIER = TARGET_MULTIPLIER,
        AutoEvolve = AutoEvolve,
        AutoAscend = AutoAscend,
        AutoCashDrop = AutoCashDrop,
        AutoVine = AutoVine,
        AutoReconnect = AutoReconnect,
        AutoSaveConfig = AutoSaveConfig
    }
    writefile(ConfigFile, HttpService:JSONEncode(data))
    
    -- Suppress notification if silent is true
    if not silent then
        Rayfield:Notify({Title = "Config Saved", Content = "Your settings have been saved successfully.", Duration = 3})
    end
end

local function LoadConfig()
    if isfile and isfile(ConfigFile) then
        local success, decoded = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if success and type(decoded) == "table" then
            if decoded.AutoBuy ~= nil and Elements.Toggles.AutoBuy then Elements.Toggles.AutoBuy:Set(decoded.AutoBuy) end
            if decoded.AutoUpgrade ~= nil and Elements.Toggles.AutoUpgrade then Elements.Toggles.AutoUpgrade:Set(decoded.AutoUpgrade) end
            if decoded.AutoPower ~= nil and Elements.Toggles.AutoPower then Elements.Toggles.AutoPower:Set(decoded.AutoPower) end
            if decoded.AutoFruit ~= nil and Elements.Toggles.AutoFruit then Elements.Toggles.AutoFruit:Set(decoded.AutoFruit) end
            if decoded.AutoPhone ~= nil and Elements.Toggles.AutoPhone then Elements.Toggles.AutoPhone:Set(decoded.AutoPhone) end
            if decoded.AutoRebirth ~= nil and Elements.Toggles.AutoRebirth then Elements.Toggles.AutoRebirth:Set(decoded.AutoRebirth) end
            if decoded.AutoEvolve ~= nil and Elements.Toggles.AutoEvolve then Elements.Toggles.AutoEvolve:Set(decoded.AutoEvolve) end
            if decoded.AutoAscend ~= nil and Elements.Toggles.AutoAscend then Elements.Toggles.AutoAscend:Set(decoded.AutoAscend) end
            if decoded.AutoCashDrop ~= nil and Elements.Toggles.AutoCashDrop then Elements.Toggles.AutoCashDrop:Set(decoded.AutoCashDrop) end
            if decoded.AutoVine ~= nil and Elements.Toggles.AutoVine then Elements.Toggles.AutoVine:Set(decoded.AutoVine) end
            if decoded.AutoReconnect ~= nil and Elements.Toggles.AutoReconnect then Elements.Toggles.AutoReconnect:Set(decoded.AutoReconnect) end
            if decoded.AutoSaveConfig ~= nil and Elements.Toggles.AutoSaveConfig then Elements.Toggles.AutoSaveConfig:Set(decoded.AutoSaveConfig) end
            
            if decoded.TARGET_MULTIPLIER ~= nil and Elements.Dropdowns.RebirthMulti then 
                Elements.Dropdowns.RebirthMulti:Set({tostring(decoded.TARGET_MULTIPLIER)}) 
            end
            Rayfield:Notify({Title = "Config Loaded", Content = "Your saved settings have been applied.", Duration = 3})
        end
    end
end

local function DeleteConfig()
    if delfile and isfile and isfile(ConfigFile) then
        delfile(ConfigFile)
        Rayfield:Notify({Title = "Config Deleted", Content = "Your saved settings file has been deleted.", Duration = 3})
    end
end

--// Auto Save Loop
task.spawn(function()
    while true do
        task.wait(10)
        if AutoSaveConfig then
            pcall(function() SaveConfig(true) end) -- Passes 'true' for silent saving
        end
    end
end)

--// Auto Reconnect Handler
GuiService.ErrorMessageChanged:Connect(function(errorMessage)
    if errorMessage and errorMessage ~= "" and AutoReconnect then
        print("Error detected: " .. errorMessage)
        if LocalPlayer then
            task.wait(1)
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end
    end
end)

